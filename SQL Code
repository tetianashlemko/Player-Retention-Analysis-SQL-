WITH First_days AS (
--Крок 1: Визначаю дату першого входу для кожного гравця
SELECT 
    player_id,
    MIN(event_date) AS first_date
FROM Activity
GROUP BY player_id
)
    SELECT 
      --Крок 2: Ділю кількість повернутих гравців на загальну кількість унікальних гравців
       ROUND(COUNT(*) * 1.0 / (SELECT COUNT(DISTINCT player_id) FROM Activity), 2) AS fraction  
    FROM Activity a
    JOIN First_days f
    ON a.player_id = f.player_id
    AND a.event_date = DATE_ADD(first_date, INTERVAL 1 DAY)
